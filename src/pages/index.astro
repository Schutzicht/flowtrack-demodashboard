---
import Base from '../layouts/Base.astro';
import Logo from '../components/Logo.astro';
import Icon from '../components/Icon.astro';
import Avatar from '../components/Avatar.astro';
import { roles, branches } from '../data/context';
---
<Base title="FlowTrack Planner — Sign in">
  <div class="min-h-screen relative overflow-hidden bg-navy text-white">
    {/* Backdrop - radial gradients + lines */}
    <div class="absolute inset-0 z-0 pointer-events-none">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_60%_at_20%_0%,rgba(17,181,197,0.28),transparent_60%),radial-gradient(ellipse_60%_50%_at_85%_100%,rgba(168,216,232,0.18),transparent_60%)]"></div>
      <svg class="absolute inset-0 w-full h-full opacity-[0.07]" viewBox="0 0 1440 900" preserveAspectRatio="none">
        <path d="M0,480 C200,400 400,560 720,480 C1040,400 1240,560 1440,480" stroke="#11B5C5" stroke-width="1.5" fill="none" />
        <path d="M0,560 C200,480 400,640 720,560 C1040,480 1240,640 1440,560" stroke="#A8D8E8" stroke-width="1" fill="none" />
      </svg>
    </div>

    {/* Background photo strip — alleen links onder de hero-tekst, niet rechts onder de kaart */}
    <div class="absolute inset-y-0 left-0 w-[40%] hidden lg:block z-0 pointer-events-none">
      <div class="absolute inset-0 opacity-[0.18]" style="background: url('/photos/team-group.jpg') center/cover;"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-navy/70 via-navy/60 to-navy"></div>
    </div>

    <div class="relative z-10 min-h-screen flex flex-col">
      <header class="px-6 lg:px-10 py-6 flex items-center justify-between">
        <Logo variant="light" />
        <div class="hidden sm:flex items-center gap-3 text-[12px] text-white/50">
          <span class="hidden md:inline">Internal planning tool</span>
          <span class="pill bg-white/[0.08] text-white/70 border border-white/10">v2.6 — concept</span>
        </div>
      </header>

      <main class="flex-1 grid lg:grid-cols-[1.1fr_minmax(440px,1fr)] gap-10 lg:gap-16 px-6 lg:px-10 pb-12 items-center max-w-[1320px] mx-auto w-full">
        <div class="max-w-xl">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/[0.08] border border-white/10 text-[12px] mb-6">
            <span class="w-1.5 h-1.5 rounded-full bg-flow pulse-ring"></span>
            Krokus + paasvakantie 2026
          </div>
          <h1 class="text-[44px] lg:text-[64px] font-display font-bold leading-[0.98] tracking-[-0.03em] text-balance">
            Een planner voor je <span class="text-flow">skischool</span>,<br class="hidden lg:block"/> surfkamp en alles daartussen.
          </h1>
          <p class="mt-6 text-white/65 text-[15.5px] leading-relaxed max-w-lg text-pretty">
            Importeer 500 inschrijvingen, laat de planner ze clusteren op niveau, leeftijd en voorkeur, en verschuif live met je team. Monitoren scannen ter plekke een QR en zien direct hun groep.
          </p>

          <div class="mt-9 grid grid-cols-2 sm:grid-cols-4 gap-3 max-w-lg">
            <div class="rounded-2xl bg-white/[0.04] border border-white/10 p-3.5 hover:bg-white/[0.06] transition-colors">
              <div class="text-[24px] font-display font-bold leading-none">522</div>
              <div class="text-[11px] text-white/55 mt-1.5">deelnemers krokus 2026</div>
            </div>
            <div class="rounded-2xl bg-white/[0.04] border border-white/10 p-3.5">
              <div class="text-[24px] font-display font-bold leading-none">95<span class="text-flow">%</span></div>
              <div class="text-[11px] text-white/55 mt-1.5">correct na dag 1</div>
            </div>
            <div class="rounded-2xl bg-white/[0.04] border border-white/10 p-3.5">
              <div class="text-[24px] font-display font-bold leading-none">5</div>
              <div class="text-[11px] text-white/55 mt-1.5">niveaus met eigen cap</div>
            </div>
            <div class="rounded-2xl bg-white/[0.04] border border-white/10 p-3.5">
              <div class="text-[24px] font-display font-bold leading-none">4</div>
              <div class="text-[11px] text-white/55 mt-1.5">locaties, multi-user</div>
            </div>
          </div>
        </div>

        {/* Sign in card */}
        <div class="relative z-20 bg-white text-ink rounded-[20px] p-6 lg:p-7 max-w-[480px] w-full justify-self-stretch lg:justify-self-end shadow-[0_24px_64px_-16px_rgba(0,0,0,0.5)]" style="background:#ffffff; color:#0A1525;">
          <div class="text-[11px] uppercase tracking-[0.08em] text-mist font-semibold mb-1">Demo sign in</div>
          <h2 class="text-[24px] font-display font-bold tracking-tight">Wie ben je vandaag?</h2>
          <p class="text-[13px] text-ink-soft mt-1 mb-5">Kies een rol om de bijbehorende rechten te zien. Wisselen kan altijd via de topbalk.</p>

          <div class="space-y-2">
            {roles.map((r) => (
              <a
                href={`/dashboard?b=ski&r=${r.id}`}
                class="group flex items-center gap-3 p-3 rounded-xl border border-line hover:border-flow hover:bg-flow-soft/40 transition-all"
              >
                <Avatar src={r.avatar} initials={r.initials} size="xl" />
                <div class="flex-1 min-w-0">
                  <div class="text-[14px] font-semibold leading-tight">{r.name}</div>
                  <div class="text-[11.5px] text-ink-soft leading-snug truncate">{r.scope}</div>
                </div>
                <Icon name="arrow-right" size={16} class="text-mist group-hover:text-flow group-hover:translate-x-0.5 transition-all" />
              </a>
            ))}
          </div>

          <div class="mt-6 pt-5 border-t border-line">
            <div class="text-[11px] uppercase tracking-[0.08em] text-mist font-semibold mb-2.5">Of start direct in branche</div>
            <div class="grid grid-cols-2 gap-2">
              {branches.map((b) => (
                <a href={`/dashboard?b=${b.id}&r=admin`} class="text-[12.5px] px-3 py-2 rounded-lg border border-line hover:border-flow hover:bg-flow-soft text-center font-medium transition-all">
                  {b.name}
                </a>
              ))}
            </div>
          </div>
        </div>
      </main>

      <footer class="px-6 lg:px-10 py-5 text-[12px] text-white/40 flex flex-wrap items-center justify-between gap-2 border-t border-white/[0.06]">
        <span>FlowTrack Travel · concept-demo door Agensea</span>
        <span>Niet verbonden met productie. Alle data is fictief.</span>
      </footer>
    </div>
  </div>
</Base>
